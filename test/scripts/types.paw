// Type inference for structure templates:
fn test_poly_struct_inference() {
    struct A<T> {
        v: T
    }
    let a = A{v: 123}
    assert(a.v == 123)

    struct B<T> {
        v: A<T>
    }
    let b = B{v: a}
    assert(b.v.v == 123)

    struct C<T> {
        v: B<T>
    }
    let c = C{v: b}
    assert(c.v.v.v == 123)
}
