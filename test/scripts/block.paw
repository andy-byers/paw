////////pub fn test_variables() {
////////// TODO: eventually refactor into closures that accept registers as arguments and return the result
//////////       avoids constant folding, once it is implemented
////////    {
////////        // # regs = 2          # r 1 2
////////        let r1 = 1; //         3   *     
////////        let r2 = r1 + r1; //   1   x *
////////    }
////////    {
////////        // # regs = 1        # r 1 2 3
////////        let r1 = 1; //       3   *       
////////        let r2 = 2; //       2     *   
////////        let r3 = r2; //      1     x *
////////    }
////////    {
////////        // # regs = 2        # r 1 2 3
////////        let r1 = 1; //       3   *       
////////        let r2 = 2; //       2   * *   
////////        let r3 = r1; //      1   x   *
////////    }
////////
////////    {
////////        // # regs = 2          # r 1 2 3
////////        let r1 = 1; //         3   *     
////////        let r2 = 2; //         2   * *   
////////        let r3 = r1 + r2; //   1   x x *
////////    }
////////
////////    {
////////        // # regs = 2          # r 1 2 3 4
////////        let r1 = 1; //         4   *     
////////        let r2 = 2; //         3   * *   
////////        let r3 = r1 + r2; //   2   * x *
////////        let r4 = r1 + r3; //   1   x   x *
////////    }
////////    {
////////        // # regs = 3          # r 1 2 3 4 5
////////        let r1 = 1; //         4   *     
////////        let r2 = 2; //         3   * *   
////////        let r3 = r1 + r2; //   2   * * *
////////        let r4 = r1 + r3; //   1   x * x *
////////        let r5 = r2 + r4; //   1     x   x *
////////    }
////////    {
////////        // # regs = 2        # r 1 2 3 4
////////        let r1 = 0; //       4   *     
////////        let r2 = 1; //       3   * *   
////////        let r3 = r1 + r2; // 2   x * *
////////        let r4 = r2 + r3; // 1     x x *
////////    }
////////
////////    {
////////        // # regs = 3        # r 1 2 3 4 5
////////        let r1 = 0; //       5   *
////////        let r2 = 1; //       4   * *
////////        let r3 = r1 + r2; // 3   * * *
////////        let r4 = r2 + r3; // 2   * x x *
////////        let r5 = r1 + r4; // 1   x     x *
////////    }
////////}
