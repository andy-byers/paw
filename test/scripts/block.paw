// block.paw

pub fn test_locals() {
    let _0 = 0;
    {
        let _1 = 1;
        let _2 = 2;
        {
            let _3 = 3;
            let _4 = 4;
            let _5 = 5;
            assert(_0 + _1 + _2 + _3 + _4 + _5 == 15);

            let _1 = 123; // shadow
            let _1 = 123; // rebind
        };
        assert(_0 + _1 + _2 == 3);

        _0 = 123; // assign
    }
    assert(_0 == 123);
}

fn check_ifelse(n: int) -> str {
    if n == 0 {
        return 'zero';
    } else if n == 1 {
        return 'one';
    } else if n == 2 {
        return 'two';
    } else {
        return 'other';
    }
}

pub fn test_ifelse() {
    assert(check_ifelse(0) == 'zero');
    assert(check_ifelse(1) == 'one');
    assert(check_ifelse(2) == 'two');
    assert(check_ifelse(3) == 'other');
    assert(check_ifelse(-1) == 'other');
}
