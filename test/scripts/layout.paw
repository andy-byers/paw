// Things that are suspicious:
//
// The "Mir::locals" list becomes outdated once SSA construction occurs. Locals that have
// at least 1 assigment are spread out over multiple versions. Indices into "Mir::locals"
// are held by items in "Mir::upvalues" that have nonzero "MirUpvalueInfo::is_local". These
// are the variables that are "captured" in the current function. Such variables still have
// multiple versions if they are assigned, but a hint is used to make sure all versions are
// allocated to the same VM register.

////function: test_nested_upvalues
////locals t, t2
////
////function: (closure)
////upvalues: t, t2
//
//pub fn test_xyz_upvalues() {
//    let v1 = 1;
//    let f = || {    
//        // locals: v2
//        // upvalues: v1
//        let v2 = 2;
//        || {
//            // locals: v3
//            // upvalues: v1, v2
//            let v3 = 3;
//            v1 + v2 + v3
//        }
//    };
//    assert(f()() == 6);
//}

pub fn test_nested_upvalues() {
    let v = 1;
    let f = || {    
        v = v + 1;
        v
    };
    assert(f() == 2);

//
//    let t = (1, 2);
//    let f = || {
//       t.0 + t.1
